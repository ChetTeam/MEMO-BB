{
  "name": "gta5rp-memo-laws",
  "version": "1.0.0",
  "description": "Overlay law memo for GTA5RP BLACKBERRY",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "parse": "node scraper.js",
    "dist": "electron-builder --win"
  },
  "author": "nanda070",
  "license": "MIT",
  "dependencies": {
    "fuse.js": "^7.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "puppeteer-core": "^21.5.0"
  },
  "build": {
    "appId": "com.nanda070.memolaws",
    "productName": "GTA5RP MEMO LAWS",
    "copyright": "Copyright © 2026 ChetTeam",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "requestedExecutionLevel": "asInvoker",
      "icon": "build/icon.ico" 
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GTA5RP MEMO LAWS",
      "installerIcon": "build/icon.ico",   
      "uninstallerIcon": "build/icon.ico",  
      "installerHeaderIcon": "build/icon.ico"
    },
    "files": [
      "**/*",
      "!dist/*",
      "!node_modules/puppeteer-core/**/*",
      "!.git/*"
    ]
  }
}