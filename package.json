{
  "name": "GTA5RP-MEMO",
  "version": "1.3.0",
  "description": "Автономный оверлей законодательной базы",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "publish": "electron-builder --win -p always"
  },
  "build": {
    "appId": "com.chetteam.memolaws",
    "artifactName": "${name}-Setup-${version}.${ext}",
    "files": [
      "**/*",
      "icon.ico"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ChetTeam",
        "repo": "MEMO-BB"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "puppeteer-core": "^25.1.0"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3"
  }
}
