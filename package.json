{
  "name": "GTA5RP-MEMO",
  "version": "1.1.3",
  "description": "Автономный оверлей законодательной базы",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.chetteam.memolaws",
    "artifactName": "${name}-Setup-${version}.${ext}",
    "files": [
      "**/*",
      "icon.ico"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ChetTeam",
        "repo": "MEMO-BB"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.1.8"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  }
}